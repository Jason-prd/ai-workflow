# AI自动化工作流 - 生产环境变量配置
# 复制此文件为 .env 并填入实际值

# ==================== 必填配置 ====================

# JWT 密钥（生产必须使用强随机密钥，建议 64+ 字符）
SECRET_KEY=your-super-secret-key-minimum-64-characters-long-xxxxxxxxxxxxxxxx

# OpenAI API Key
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ==================== 可选配置 ====================

# 调试模式（生产必须为 false）
DEBUG=false

# 访问令牌过期时间（分钟）
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# OpenAI 模型配置
OPENAI_MODEL=gpt-4o-mini
OPENAI_MAX_TOKENS=2000
OPENAI_TEMPERATURE=0.7

# 飞书配置（从飞书开放平台获取）
FEISHU_APP_ID=cli_xxxxxxxxxxxxxxxxxxxxxxxx
FEISHU_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
FEISHU_VERIFICATION_TOKEN=your_verification_token
FEISHU_ENCRYPT_KEY=your_encrypt_key

# 飞书日历轮询配置
FEISHU_CALENDAR_POLL_INTERVAL_SECONDS=60
FEISHU_CALENDAR_REMIND_MINUTES=5

# 工作流执行配置
MAX_NODES_PER_WORKFLOW=20
MAX_CONCURRENT_EXECUTIONS=5
EXECUTION_TIMEOUT_SECONDS=60

# 执行日志保留配置
MAX_EXECUTION_LOGS=100
LOG_RETENTION_DAYS=7
